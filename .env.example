# Copy to `.env` and fill in values. Never commit `.env`.

# SofaScore via RapidAPI (shared with BallistiXG)
# https://rapidapi.com/apisummit/api/sofascore-sport-api
SOFASCORE_RAPIDAPI_KEY=

# OpenRouter LLM (key to be provided separately)
# https://openrouter.ai/
OPENROUTER_API_KEY=

# Optional: quota protection defaults
SOFASCORE_QUOTA_PROTECT=500
SOFASCORE_MIN_REMAINING_BEFORE_FETCH=10
